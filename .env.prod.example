# ==========================================================
# PRODUCTION environment (on-prem). Copy to .env and fill in.
# NEVER commit the real .env. Lock it down: chmod 600 .env
# ==========================================================

# ---- Public address (served by Caddy over HTTPS) ----
# A hostname resolvable on the clinic LAN. Point the tablets/router DNS at this
# server's IP for this name. Caddy issues a trusted-locally certificate for it.
SITE_ADDRESS=rehab.clinic.lan

# ---- Postgres (internal only; not exposed to the network) ----
POSTGRES_USER=rehab
POSTGRES_PASSWORD=__CHANGE_ME__strong_random__
POSTGRES_DB=rehab

# ---- Auth secrets ----
# Generate with:  openssl rand -hex 32
JWT_ACCESS_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__CHANGE_ME__another_openssl_rand_hex_32__
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- First admin user (created once by the init job) ----
BOOTSTRAP_ADMIN_EMAIL=admin@clinic.local
BOOTSTRAP_ADMIN_PASSWORD=__CHANGE_ME__strong_admin_password__
BOOTSTRAP_CLINIC_NAME=My Clinic

# ---- Localization ----
DEFAULT_LOCALE=hy
