# ==========================================================
# Rehab App — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ==========================================================

# ---- Postgres ----
POSTGRES_USER=rehab
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=rehab
POSTGRES_PORT=5432

# Connection string for HOST-based tooling (pnpm dev, db:migrate, db:seed) — uses
# localhost against the Postgres port published by docker compose. Inside Docker the
# API container gets DATABASE_URL with host "db" (set in docker-compose.yml).
DATABASE_URL=postgresql://rehab:change_me_in_real_env@localhost:5432/rehab

# ---- API ----
API_PORT=3001
NODE_ENV=development

# Auth — generate strong random values in real environments.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Web ----
WEB_PORT=5173
# Base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:3001

# ---- Localization ----
DEFAULT_LOCALE=hy
